DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://itda:itda@localhost:5432/itda_language

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-secret-key-here

# CLOVA Voice API (https://console.ncloud.com)
CLOVA_CLIENT_ID=your-clova-client-id
CLOVA_CLIENT_SECRET=your-clova-client-secret

# Object Storage
S3_ENDPOINT_URL=https://kr.object.ncloudstorage.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET_NAME=itda-voices

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
